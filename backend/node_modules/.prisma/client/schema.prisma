generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(uuid())
  pan                String   @unique
  phoneNumber        String   @unique
  email              String   @unique
  password           String
  name               String   @default("")
  rating             Float    @default(0)
  ratingCount        Int      @default(0)
  numberOfFlags      Int      @default(0)
  role               Role     @default(USER)
  isBlocked          Boolean  @default(false)
  isVerified         Boolean  @default(false)
  verifyToken        String?
  favoriteCategories String[] @default([])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  products         Product[]
  auctions         AuctionRoom[]  @relation("SellerAuctions")
  wonAuctions      AuctionRoom[]  @relation("WinnerAuctions")
  bids             Bid[]
  commentsMade     Comment[]      @relation("CommentAuthor")
  commentsReceived Comment[]      @relation("CommentTarget")
  ratingsGiven     Rating[]       @relation("RatingAuthor")
  ratingsReceived  Rating[]       @relation("RatingTarget")
  flags            Flag[]         @relation("FlagAuthor")
  flagsReceived    Flag[]         @relation("FlagTarget")
  notifications    Notification[]
}

enum Role {
  USER
  ADMIN
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String
  category    String
  basePrice   Float
  images      String[] @default([])
  sellerId    String
  seller      User     @relation(fields: [sellerId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  auction AuctionRoom?
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model AuctionRoom {
  id             String        @id @default(uuid())
  productId      String        @unique
  product        Product       @relation(fields: [productId], references: [id])
  sellerId       String
  seller         User          @relation("SellerAuctions", fields: [sellerId], references: [id])
  highestBuyerId String?
  highestBuyer   User?         @relation("WinnerAuctions", fields: [highestBuyerId], references: [id])
  bestPrice      Float         @default(0)
  type           AuctionType
  endTime        DateTime?
  status         AuctionStatus @default(ACTIVE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  bids Bid[]
}

enum AuctionType {
  TIME_BOUND
  OPEN
}

enum AuctionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model Bid {
  id            String      @id @default(uuid())
  amount        Float
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  auctionRoomId String
  auctionRoom   AuctionRoom @relation(fields: [auctionRoomId], references: [id])
  status        BidStatus   @default(VALID)
  createdAt     DateTime    @default(now())
}

enum BidStatus {
  VALID
  WITHDRAWN
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  authorId  String
  author    User     @relation("CommentAuthor", fields: [authorId], references: [id])
  targetId  String
  target    User     @relation("CommentTarget", fields: [targetId], references: [id])
  createdAt DateTime @default(now())
}

model Rating {
  id                  String   @id @default(uuid())
  productQuality      Int // 1-5
  descriptionAccuracy Int // 1-5
  overallScore        Float
  authorId            String
  author              User     @relation("RatingAuthor", fields: [authorId], references: [id])
  targetId            String
  target              User     @relation("RatingTarget", fields: [targetId], references: [id])
  auctionId           String
  createdAt           DateTime @default(now())
}

model Flag {
  id        String   @id @default(uuid())
  reason    String
  authorId  String
  author    User     @relation("FlagAuthor", fields: [authorId], references: [id])
  targetId  String
  target    User     @relation("FlagTarget", fields: [targetId], references: [id])
  reviewed  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String // 'bid_update', 'auction_won', 'auction_ended', 'flagged', 'outbid'
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
